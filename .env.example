# Phase 0 local stack secrets. Copy to .env and fill in.
#   cp .env.example .env
# Generate the two GrowthBook secrets with:  openssl rand -hex 32
#
# ENCRYPTION_KEY is "sacred" (PLAN.md:240): it encrypts data-source credentials in
# Mongo. Once you've created the data source in the UI, do NOT change this value or
# GrowthBook can no longer decrypt those credentials.

# --- GrowthBook ---
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me

# --- Mongo (GrowthBook's app database) ---
MONGO_USER=root
MONGO_PASSWORD=password

# --- Postgres (the demo warehouse) ---
POSTGRES_USER=gbsynth
POSTGRES_PASSWORD=gbsynth
POSTGRES_DB=warehouse

# --- GrowthBook REST API (fill in after the UI setup step) ---
# Create a key in the UI: Settings → API Keys → Secret key (admin role).
GB_API_HOST=http://localhost:3100
GB_API_KEY=
